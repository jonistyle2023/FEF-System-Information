<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ec.edu.upse.FEF.controlador.PrincipalController">
    <padding>
        <Insets bottom="12" left="12" right="12" top="12"/>
    </padding>

    <Label text="Sistema de Gestion FEF" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TabPane tabClosingPolicy="UNAVAILABLE">
        <tabs>
            <Tab text="Equipo">
                <GridPane hgap="10" vgap="10">
                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12"/>
                    </padding>
                    <Label text="Nombre equipo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtNombreEquipo" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Ciudad:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtCiudad" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="cbEstado" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Button text="Registrar equipo" onAction="#registrarEquipo" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>
            </Tab>

            <Tab text="Utileria">
                <GridPane hgap="10" vgap="10">
                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12"/>
                    </padding>
                    <Label text="Equipo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbEquipoUtilero" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="CI:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtCiUtilero" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Nombres:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtNombreUtilero" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Ocupacion:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtOcupacionUtilero" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Button text="Registrar utilero" onAction="#registrarUtilero" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>
            </Tab>

            <Tab text="Directivos">
                <GridPane hgap="10" vgap="10">
                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12"/>
                    </padding>
                    <Label text="Equipo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbEquipoDirectivo" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="CI:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtCiDirectivo" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Nombres:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtNombreDirectivo" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Cargo:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtCargoDirectivo" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Button text="Registrar directivo" onAction="#registrarDirectivo" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>
            </Tab>

            <Tab text="Equipo tecnico">
                <GridPane hgap="10" vgap="10">
                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12"/>
                    </padding>
                    <Label text="Equipo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbEquipoTecnico" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="CI:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtCiTecnico" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Nombres:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtNombreTecnico" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Nacionalidad:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtNacionalidadTecnico" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Label text="Cargo:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="txtCargoTecnico" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    <Button text="Registrar tecnico" onAction="#registrarTecnico" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                </GridPane>
            </Tab>

            <Tab text="Jugadores">
                <GridPane hgap="10" vgap="10">
                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12"/>
                    </padding>
                    <Label text="Equipo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbEquipoJugador" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="CI:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="txtCiJugador" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Nombres:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtNombreJugador" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Posicion:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <ComboBox fx:id="cbPosicionJugador" prefWidth="220" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Label text="Edad:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="txtEdadJugador" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    <Label text="Peso (kg):" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <TextField fx:id="txtPesoJugador" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    <Button text="Registrar jugador" onAction="#registrarJugador" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                </GridPane>
            </Tab>

            <Tab text="Resumen">
                <GridPane hgap="10" vgap="10">
                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12"/>
                    </padding>
                    <Label text="Equipo:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="cbEquipoResumen" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Button text="Ver resumen" onAction="#cargarResumenEquipo" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Button text="Ver nomina completa" onAction="#cargarNominaCompletaEquipo" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    <TextArea fx:id="taResumen" prefHeight="300" prefWidth="700" editable="false"
                              GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="4"/>
                </GridPane>
            </Tab>
        </tabs>
    </TabPane>
</VBox>

